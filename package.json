{
  "name": "inquisitor",
  "version": "0.1.0",
  "description": "高强度代码审查工具 - 以对抗式 Agent 模式深度审查代码质量",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "lint": "eslint src/",
    "clean": "rm -rf dist/",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "code-review",
    "agent",
    "adversarial",
    "static-analysis"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "glob": "^13.0.6"
  }
}
